# ============================================================
# SaralOps — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- NextAuth ---
AUTH_SECRET=your-random-secret-here-run-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# --- Google OAuth ---
# Optional. If unset, Google login uses GOOGLE_DRIVE_OAUTH_CLIENT_ID / GOOGLE_DRIVE_OAUTH_CLIENT_SECRET.
# AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=your-google-client-secret

# --- Microsoft / Azure AD OAuth ---
AUTH_MICROSOFT_ENTRA_ID_ID=your-azure-app-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-azure-app-client-secret
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=your-azure-tenant-id-or-common

# --- Database (Neon Postgres) ---
# Get from: https://console.neon.tech → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/saralops?sslmode=require

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SaralOps

# Comma-separated list of auto-approved email domains
AUTO_APPROVE_DOMAINS=saralvidhya.com,sarallabs.com

# --- Google Drive uploads ---
GOOGLE_DRIVE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_DRIVE_REFRESH_TOKEN=your-refresh-token
GOOGLE_DRIVE_FOLDER_ID=your-shared-drive-folder-id
# Defaults to public reader links so embeds work for signed-in app users.
GOOGLE_DRIVE_SHARE_ANYONE=true
