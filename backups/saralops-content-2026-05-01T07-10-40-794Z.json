      {
        "id": "b51f29cc-a360-4933-84c8-44e8ece89440",
        "workspace_id": "510dc39b-ce1b-48a1-ab1f-8f4e8801d086",
        "project_id": null,
        "title": "Nirnayah",
        "content": "<h1>Nirnayah Features</h1><p></p>",
        "author_id": "3e604637-3341-46cd-8514-be1da2d7a9c8",
        "parent_id": null,
        "slug": null,
        "is_published": false,
        "emoji": "📄",
        "created_at": "2026-04-27T06:28:40.850Z",
        "updated_at": "2026-04-30T05:32:05.140Z",
        "space_id": null,
        "draft_content": "<h1>Nirnayah Features</h1><div data-drive-embed=\"\" data-src=\"https://drive.google.com/file/d/1MVYNGW70zW_LeFGNxuDaTHmBQhIfoWu_/preview\" data-direct-url=\"https://drive.google.com/uc?export=view&amp;id=1MVYNGW70zW_LeFGNxuDaTHmBQhIfoWu_\" data-title=\"2.jpg\" data-mime-type=\"image/jpeg\" data-kind=\"image\" class=\"drive-embed my-3\"><iframe src=\"https://drive.google.com/file/d/1MVYNGW70zW_LeFGNxuDaTHmBQhIfoWu_/preview\" title=\"2.jpg\" class=\"drive-embed-frame\" allow=\"autoplay; encrypted-media\" allowfullscreen=\"true\" loading=\"lazy\"></iframe></div><p></p>",
        "status": "draft",
        "access_level": "workspace",
        "depth": 0,
        "is_blog_post": false,
        "cover_image": null
      },
      {
        "id": "b98e1371-d3cc-4f6c-b0c8-890d683c0149",
        "workspace_id": "74901b85-24ef-4ff6-a1a6-c99e94e37002",
        "project_id": null,
        "title": "Nirnayah",
        "content": "<h1>Untitled Page</h1><p></p>",
        "author_id": "b4ba4e61-78af-48bb-a4c7-f94a86bd38ff",
        "parent_id": null,
        "slug": null,
        "is_published": false,
        "emoji": "📄",
        "created_at": "2026-04-29T22:24:05.910Z",
        "updated_at": "2026-04-30T05:51:49.160Z",
        "space_id": "853d3ae0-9cea-4e62-aded-b06cd1a07fd0",
        "draft_content": "<p>Evaluation Platform</p><p></p><p><strong>Nirnayah</strong> addresses descriptive answer sheet evaluation gap, a massive pain point in Indian academics that current proctoring-focused platforms ignore.</p><p></p><p>🎯 <strong>Blueprint</strong>: AI-Powered Digital Evaluation System for Indian Academics</p><p></p><p><strong><u>Executive Summary</u></strong></p><p></p><p><strong>Nirnayah</strong> platform addresses a <strong>critical gap</strong> in the Indian EdTech Market. While existing solutions focus on proctoring or MCQ grading, <strong>descriptive answer evaluation with handwriting recognition</strong> remains largely manual. Recent breakthroughs show <strong>95%+ accuracy</strong> in handwritten text recognition&nbsp; and <strong>AI grading outperforming human experts</strong> in consistency.</p><p></p><p><strong>Key Innovation</strong>: Human-in-the-loop AI evaluation specifically designed for Indian examination patterns (essay-type, mixed languages, mathematical notation).</p><p></p><h1><strong>Core Architecture Design</strong></h1><p></p><div data-drive-embed=\"\" data-src=\"https://drive.google.com/file/d/1JzQLz_islzY_oDKMvQ_w7cGHippSEvOC/preview\" data-direct-url=\"https://drive.google.com/uc?export=view&amp;id=1JzQLz_islzY_oDKMvQ_w7cGHippSEvOC\" data-title=\"Nirnayah-Arch.jpg\" data-mime-type=\"image/jpeg\" data-kind=\"image\" class=\"drive-embed my-3\"><iframe src=\"https://drive.google.com/file/d/1JzQLz_islzY_oDKMvQ_w7cGHippSEvOC/preview\" title=\"Nirnayah-Arch.jpg\" class=\"drive-embed-frame\" allow=\"autoplay; encrypted-media\" allowfullscreen=\"true\" loading=\"lazy\"></iframe></div><p></p><p><strong>Technical Stack</strong></p><p></p><table style=\"min-width: 75px;\"><colgroup><col style=\"min-width: 25px;\"><col style=\"min-width: 25px;\"><col style=\"min-width: 25px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Component</p></th><th colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Technology</p></th><th colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Purpose</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Handwritten Text Recognition</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>TrOCR / EasyOCR + Custom HTR</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Extract text from answer sheets</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Multimodal Recognition</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Vision-Language Models (VLMs)</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Handle diagrams, math formulas</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Semantic Evaluation</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Universal Sentence Encoder + SBERT</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Compare meaning, not just keywords</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Similarity Scoring</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Cosine Similarity + Jaccard + Edit Distance</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Multi-metric confidence scoring</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>UI Framework</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>React/Vue.js + Canvas API</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Side-by-side comparison interface</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Backend</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Python (FastAPI) + PostgreSQL</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>High-throughput evaluation API</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Document Processing</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>OpenCV + Pillow</p></td><td colspan=\"1\" rowspan=\"1\" style=\"text-align: left;\"><p>Image preprocessing, deskewing</p></td></tr></tbody></table><p></p><p><strong>The Evaluation Workflow (Human-in-the-Loop)</strong></p><p></p><div data-drive-embed=\"\" data-src=\"https://drive.google.com/file/d/1mIWjuIpirjW-M0jqzgP9MFG39vDpJakK/preview\" data-direct-url=\"https://drive.google.com/uc?export=view&amp;id=1mIWjuIpirjW-M0jqzgP9MFG39vDpJakK\" data-title=\"Screenshot 2026-04-30 at 4.48.01 PM.png\" data-mime-type=\"image/png\" data-kind=\"image\" class=\"drive-embed my-3\"><iframe src=\"https://drive.google.com/file/d/1mIWjuIpirjW-M0jqzgP9MFG39vDpJakK/preview\" title=\"Screenshot 2026-04-30 at 4.48.01 PM.png\" class=\"drive-embed-frame\" allow=\"autoplay; encrypted-media\" allowfullscreen=\"true\" loading=\"lazy\"></iframe></div><p></p><p></p>",
